import path from "node:path"

const HOOK_PATH = "__HOOK_PATH__"

function requestKey(sessionID, callID) {
  return `${sessionID}:${callID}`
}

function resolveCwd(directory, workdir) {
  if (!workdir) return directory
  return path.isAbsolute(workdir) ? workdir : path.resolve(directory, workdir)
}

function decode(buffer) {
  return new TextDecoder().decode(buffer).trim()
}

export const BashApprovePlugin = async ({ directory, client }) => {
  const pending = new Map()

  async function log(level, message, extra = {}) {
    await client.app.log({
      body: {
        service: "bash-approve-opencode",
        level,
        message,
        extra,
      },
    })
  }

  function evaluate(command, cwd) {
    const proc = Bun.spawnSync({
      cmd: [HOOK_PATH],
      stdin: JSON.stringify({ tool: "bash", command, cwd }),
      stdout: "pipe",
      stderr: "pipe",
    })

    if (proc.exitCode !== 0) {
      return { decision: "ask", reason: decode(proc.stderr) }
    }

    const stdout = decode(proc.stdout)
    if (!stdout) return { decision: "ask" }

    try {
      return JSON.parse(stdout)
    } catch {
      return { decision: "ask", reason: stdout }
    }
  }

  return {
    "tool.execute.before": async (input, output) => {
      if (input.tool !== "bash") return
      pending.set(requestKey(input.sessionID, input.callID), {
        command: output.args.command,
        cwd: resolveCwd(directory, output.args.workdir),
      })
    },

    "tool.execute.after": async (input) => {
      if (input.tool !== "bash") return
      pending.delete(requestKey(input.sessionID, input.callID))
    },

    "permission.ask": async (input, output) => {
      if (input.permission !== "bash") return

      const cached = input.tool ? pending.get(requestKey(input.sessionID, input.tool.callID)) : undefined
      const command = cached?.command ?? input.patterns.join(" && ")
      const cwd = cached?.cwd ?? directory
      const decision = evaluate(command, cwd)

      if (decision.decision === "allow") {
        output.status = "allow"
        return
      }

      if (decision.decision === "deny") {
        output.status = "deny"
        return
      }

      output.status = "ask"
      if (decision.reason) {
        await log("debug", "OpenCode adapter deferred to ask", {
          command,
          cwd,
          reason: decision.reason,
        })
      }
    },
  }
}
